# ==========================================
# VideoScribe Application Settings
# ==========================================

BACKEND_PORT=3000

# --- AI Provider Configuration ---
# Supported providers: OLLAMA, VERTEX, GEMINIFLOW
AI_PROVIDER=GEMINIFLOW
AI_MODEL=gemini-3.5-flash

# --- Ollama Settings ---
# The URL of your local or remote Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# --- GCP Vertex AI Settings ---
# Your Google Cloud Project ID and region
VERTEX_PROJECT_ID=your-project-id
VERTEX_REGION=us-central1
# Your GCP Access Token (Run `gcloud auth print-access-token` to get one)
VERTEX_ACCESS_TOKEN=your-access-token

# --- GeminiFlow Settings ---
# The URL of your local GeminiFlow server
GEMINIFLOW_BASE_URL=http://127.0.0.1:8000
