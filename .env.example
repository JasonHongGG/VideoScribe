# ==========================================
# Agent Configuration
# ==========================================
# Specify the AI Provider for the Translator Agent
# Options: ollama, vertex
VITE_AGENT_TRANSLATOR_PROVIDER=vertex

# Specify the model to use for the Translator Agent
# For ollama: qwen3.6:35b, llama3, mistral, etc.
# For vertex: gemini-3.5-flash, gemini-1.5-pro, etc.
VITE_AGENT_TRANSLATOR_MODEL=gemini-3.5-flash


# ==========================================
# Ollama Provider Settings
# ==========================================
# The URL of your local or remote Ollama instance
VITE_PROVIDER_OLLAMA_URL=


# ==========================================
# GCP Vertex AI Provider Settings
# ==========================================
# Your Google Cloud Project ID
VITE_PROVIDER_VERTEX_PROJECT_ID=cedar-shard-491718-u4

# The region where your Vertex AI model is hosted (e.g., us-central1, asia-east1)
VITE_PROVIDER_VERTEX_REGION=global

# Your GCP Access Token (Run `gcloud auth print-access-token` to get one)
VITE_PROVIDER_VERTEX_ACCESS_TOKEN=your-access-token-here
